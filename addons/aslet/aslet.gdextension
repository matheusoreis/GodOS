[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
windows.debug.x86_64 = "res://addons/aslet/aslet.dll"
windows.release.x86_64 = "res://addons/aslet/aslet.dll"
macos.debug = "res://addons/aslet/libaslet.dylib"
macos.release = "res://addons/aslet/libaslet.dylib"